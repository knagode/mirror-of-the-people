<div class="my-wishes">
  <h1>Moje želje</h1>
  <p class="subtitle">Tvoj skupni profil na podlagi <%= @wishes.count %> <%= @wishes.count == 1 ? "želje" : "želj" %>.</p>

  <div class="profile-url-box">
    <p>Shrani ta URL, da ohraniš dostop do svojega profila. Z njim se lahko vrneš kadarkoli, tudi iz drugega brskalnika.</p>
    <div class="profile-url-field">
      <input type="text" value="<%= profile_url(@profile.token) %>" readonly class="profile-url-input" id="profile-url">
      <button onclick="navigator.clipboard.writeText(document.getElementById('profile-url').value).then(() => this.textContent = 'Kopirano!')" class="btn btn-small">Kopiraj</button>
    </div>
  </div>

  <% if @party_scores.any? %>
    <h2>Tvoje povprečno ujemanje s strankami</h2>
    <div class="matches">
      <% @party_scores.each_with_index do |data, index| %>
        <div class="match-card">
          <div class="match-header">
            <div class="match-rank">#<%= index + 1 %></div>
            <div class="match-info">
              <h3><%= data[:name] %></h3>
            </div>
            <div class="match-score <%= score_class(data[:avg_score]) %>">
              <%= data[:avg_score] %>%
            </div>
          </div>
          <div class="match-bar-container">
            <div class="match-bar <%= score_class(data[:avg_score]) %>" style="width: <%= data[:avg_score] %>%"></div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <h2>Vse tvoje želje</h2>
  <% if @wishes.any? %>
    <div class="recent-wishes">
      <% @wishes.each do |wish| %>
        <%= render "wishes/wish", wish: wish %>
      <% end %>
    </div>
  <% else %>
    <p class="subtitle">Še nimaš nobene želje. <%= link_to "Napiši svojo prvo željo!", root_path %></p>
  <% end %>
</div>
